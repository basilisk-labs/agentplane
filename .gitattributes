# Auto detect text files and keep normalized line endings.
* text=auto
*.md text eol=lf working-tree-encoding=UTF-8
*.mdx text eol=lf working-tree-encoding=UTF-8
*.html text eol=lf working-tree-encoding=UTF-8
*.txt text eol=lf working-tree-encoding=UTF-8
*.json text eol=lf working-tree-encoding=UTF-8
*.yaml text eol=lf working-tree-encoding=UTF-8
*.yml text eol=lf working-tree-encoding=UTF-8
*.ts text eol=lf working-tree-encoding=UTF-8
*.tsx text eol=lf working-tree-encoding=UTF-8
*.js text eol=lf working-tree-encoding=UTF-8
*.mjs text eol=lf working-tree-encoding=UTF-8
*.cjs text eol=lf working-tree-encoding=UTF-8
*.css text eol=lf working-tree-encoding=UTF-8

*.webmanifest text eol=lf working-tree-encoding=UTF-8

.agentplane/tasks.json export-ignore
.agentplane/tasks/**/runs export-ignore
.agentplane/tasks/**/runs/** export-ignore
.agentplane/tasks/**/repro export-ignore
.agentplane/tasks/**/repro/** export-ignore
.agentplane/tasks/**/*.log export-ignore
.agentplane/tasks/**/*.jsonl export-ignore
.agentplane/cache/** export-ignore
.agentplane/bin/** export-ignore
.agentplane/.npm-cache/** export-ignore
.agentplane/.release/** export-ignore
.agentplane/.upgrade/** export-ignore

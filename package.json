{
  "name": "agentplane-repo",
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.6",
  "scripts": {
    "postinstall": "lefthook install",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "bun run test:fast",
    "test:fast": "vitest run --exclude \"**/cli-smoke.test.ts\" --exclude \"**/run-cli*.test.ts\"",
    "test:fast:hook": "vitest run --exclude \"**/cli-smoke.test.ts\" --exclude \"**/run-cli*.test.ts\" --exclude \"**/commands/workflow.test.ts\"",
    "test:precommit": "vitest run packages/agentplane/src/commands/shared/network-approval.test.ts packages/agentplane/src/commands/shared/approval-requirements.test.ts packages/agentplane/src/commands/task/shared.unit.test.ts packages/agentplane/src/commands/task/shared.verify-steps.test.ts packages/agentplane/src/commands/task/warn-owner.unit.test.ts packages/agentplane/src/shared/comment-format.test.ts packages/agentplane/src/shared/errors.test.ts packages/agentplane/src/shared/agent-emoji.unit.test.ts packages/agentplane/src/cli/spec/parse.test.ts packages/agentplane/src/cli/spec/help-render.test.ts packages/agentplane/src/cli/spec/registry.test.ts packages/agentplane/src/cli/spec/suggest.test.ts packages/agentplane/src/cli/output.test.ts packages/agentplane/src/cli/prompts.test.ts packages/agentplane/src/cli/error-map.test.ts packages/agentplane/src/backends/task-backend/redmine/env.test.ts packages/core/src/config/execution-profile.test.ts packages/core/src/config/config.test.ts",
    "test:hooks": "vitest run packages/agentplane/src/commands/workflow.test.ts packages/agentplane/src/cli/run-cli.core.hooks.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:agentplane": "vitest run packages/agentplane/src --exclude \"**/cli-smoke.test.ts\" --exclude \"**/run-cli*.test.ts\"",
    "test:core": "vitest run packages/core/src",
    "test:recipes": "vitest run packages/recipes/src",
    "test:testkit": "vitest run packages/testkit/src",
    "test:cli": "vitest run packages/agentplane/src/cli/run-cli.core*.test.ts packages/agentplane/src/cli/run-cli.recipes.test.ts packages/agentplane/src/cli/run-cli.scenario.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:cli:unit": "vitest run packages/agentplane/src/cli/run-cli.core*.test.ts packages/agentplane/src/cli/run-cli.recipes.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:cli:core": "vitest run packages/agentplane/src/cli/run-cli.core*.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:cli:recipes": "vitest run packages/agentplane/src/cli/run-cli.recipes.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:cli:scenario": "vitest run packages/agentplane/src/cli/run-cli.scenario.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:cli:smoke": "vitest run packages/agentplane/src/cli/cli-smoke.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:cli:slow": "vitest run packages/agentplane/src/cli/run-cli.scenario.test.ts packages/agentplane/src/cli/cli-smoke.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:critical": "bun run test:critical:exit-codes && bun run test:critical:git-edge && bun run test:critical:protected-paths && bun run test:critical:scope-leak && bun run test:critical:symlink-root",
    "test:critical:exit-codes": "vitest run packages/agentplane/src/cli/run-cli.critical.exit-codes.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:critical:git-edge": "vitest run packages/agentplane/src/cli/run-cli.critical.git-edge.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:critical:protected-paths": "vitest run packages/agentplane/src/cli/run-cli.critical.protected-paths.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:critical:scope-leak": "vitest run packages/agentplane/src/cli/run-cli.critical.scope-leak.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:critical:symlink-root": "vitest run packages/agentplane/src/cli/run-cli.critical.symlink-root.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:platform-critical": "bun run test:platform-critical:pr-meta && bun run test:platform-critical:scenario && bun run test:platform-critical:init-upgrade-backend",
    "test:platform-critical:init-upgrade-backend": "vitest run packages/agentplane/src/cli/run-cli.core.init-upgrade-backend.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:platform-critical:pr-meta": "vitest run packages/agentplane/src/commands/shared/pr-meta.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:platform-critical:scenario": "vitest run packages/agentplane/src/commands/scenario/impl/commands.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:backend-critical": "vitest run packages/agentplane/src/backends/task-backend.test.ts packages/agentplane/src/backends/task-backend/redmine/env.test.ts packages/agentplane/src/commands/backend.test.ts packages/agentplane/src/commands/shared/task-backend.test.ts packages/agentplane/src/commands/task/export.unit.test.ts packages/agentplane/src/commands/task/migrate-doc.test.ts packages/agentplane/src/commands/doctor.fast.test.ts packages/agentplane/src/cli/run-cli.core.init-upgrade-backend.test.ts packages/agentplane/src/cli/run-cli.core.tasks.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:backend:redmine-live": "node scripts/run-backend-live-suite.mjs",
    "test:backend:matrix": "bun run test:backend-critical && bun run test:backend:redmine-live",
    "test:workflow-coverage": "node scripts/run-workflow-coverage-suite.mjs",
    "test:significant-coverage": "node scripts/run-significant-coverage-suite.mjs",
    "test:guard": "vitest run packages/agentplane/src/commands/guard/index.test.ts packages/agentplane/src/commands/guard/impl/allow.test.ts packages/agentplane/src/commands/guard/impl/comment-commit.test.ts packages/agentplane/src/commands/guard/impl/commands.unit.test.ts packages/agentplane/src/commands/guard/impl/policy.test.ts packages/agentplane/src/commands/guard/impl/close-message.test.ts",
    "test:full": "vitest run",
    "test:release:ci-base": "vitest run --exclude \"**/cli-smoke.test.ts\" --exclude \"**/release-recovery-script.test.ts\" --exclude \"**/run-cli.core.init-upgrade-backend.test.ts\"",
    "test:release:recovery": "vitest run packages/agentplane/src/cli/release-recovery-script.test.ts --hookTimeout 60000 --testTimeout 60000",
    "test:release:smoke": "vitest run packages/agentplane/src/cli/release-smoke.test.ts --hookTimeout 120000 --testTimeout 120000",
    "test:release:critical": "bun run test:release:recovery && bun run test:release:smoke && bun run test:cli:smoke",
    "coverage": "vitest run --coverage",
    "ci": "bun run format:check && bun run schemas:check && bun run agents:check && bun run policy:routing:check && bun run release:parity && bun run typecheck && bun run docs:bootstrap:check && bun run docs:onboarding:check && bun run lint:core && bun run coverage && bun run coverage:significant",
    "ci:local": "node scripts/run-local-ci.mjs --mode fast",
    "ci:local:fast": "node scripts/run-local-ci.mjs --mode fast",
    "ci:local:full": "node scripts/run-local-ci.mjs --mode full",
    "ci:agentplane": "node scripts/ci-scope.mjs --scope agentplane",
    "ci:core": "node scripts/ci-scope.mjs --scope core",
    "ci:recipes": "node scripts/ci-scope.mjs --scope recipes",
    "ci:spec": "node scripts/ci-scope.mjs --scope spec",
    "ci:testkit": "node scripts/ci-scope.mjs --scope testkit",
    "release:check": "bun run --filter=@agentplaneorg/core build && bun run --filter=agentplane build && node scripts/release-check.mjs",
    "release:check:registry": "node scripts/check-npm-version-availability.mjs",
    "release:recover": "node scripts/check-release-recovery-state.mjs",
    "release:smoke:published": "node scripts/check-published-packages.mjs",
    "release:ci-check": "bun run format:check && bun run schemas:check && bun run agents:check && bun run policy:routing:check && bun run release:parity && bun run build && bun run docs:cli:check && bun run docs:bootstrap:check && bun run docs:onboarding:check && bun run lint:core && GIT_AUTHOR_NAME=agentplane-ci GIT_AUTHOR_EMAIL=agentplane-ci@example.com GIT_COMMITTER_NAME=agentplane-ci@example.com GIT_COMMITTER_EMAIL=agentplane-ci@example.com bun run test:release:ci-base && GIT_AUTHOR_NAME=agentplane-ci GIT_AUTHOR_EMAIL=agentplane-ci@example.com GIT_COMMITTER_NAME=agentplane-ci@example.com GIT_COMMITTER_EMAIL=agentplane-ci@example.com bun run test:release:critical",
    "release:prepublish": "bun run release:ci-check && bun run release:check",
    "release:parity": "node scripts/check-release-parity.mjs",
    "lint": "bun run lint:core && bun run lint:website",
    "lint:core": "eslint packages scripts eslint.config.cjs vitest.config.ts",
    "lint:website": "eslint website",
    "workflows:lint": "node scripts/run-workflows-lint.mjs && node scripts/check-workflow-command-contract.mjs",
    "workflows:command-check": "node scripts/check-workflow-command-contract.mjs",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "hooks:install": "lefthook install",
    "agents:check": "node scripts/sync-agent-templates.mjs check",
    "policy:routing:check": "node scripts/check-policy-routing.mjs",
    "agents:sync": "node scripts/sync-agent-templates.mjs sync",
    "schemas:check": "node scripts/sync-schemas.mjs check",
    "schemas:sync": "node scripts/sync-schemas.mjs sync",
    "coverage:significant": "node scripts/check-significant-coverage.mjs",
    "coverage:workflow-harness": "node scripts/check-workflow-harness-coverage.mjs",
    "docs:cli:check": "node scripts/check-cli-reference-fresh.mjs",
    "docs:bootstrap:generate": "node scripts/generate-agent-bootstrap-doc.mjs",
    "docs:bootstrap:check": "node scripts/check-agent-bootstrap-fresh.mjs",
    "docs:onboarding:check": "node scripts/check-agent-onboarding-scenario.mjs",
    "docs:site:generate": "node scripts/generate-website-docs.mjs",
    "docs:site:typecheck": "bun run --cwd website typecheck",
    "docs:site:build": "bun run --cwd website build",
    "docs:site:start": "bun run --cwd website start",
    "docs:site:check:design": "node scripts/check-design-language.mjs",
    "docs:site:check": "bun run docs:site:generate && bun run docs:site:typecheck && bun run docs:site:build && bun run docs:site:check:design"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.1.0",
    "lefthook": "^2.0.16",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

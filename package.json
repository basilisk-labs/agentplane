{
  "name": "agentplane-repo",
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.6",
  "scripts": {
    "postinstall": "lefthook install",
    "build": "tsc -b && bun run --filter=@agentplaneorg/core build:bundle && bun run --filter=@agentplaneorg/recipes build:bundle && bun run --filter=agentplane build:bundle",
    "typecheck": "tsc -b",
    "test": "bun run test:fast",
    "test:fast": "vitest --config vitest.workspace.ts run --project agentplane --project core --project recipes --project testkit",
    "test:project": "vitest --config vitest.workspace.ts run --project",
    "test:precommit": "node scripts/checks/run-vitest-suite.mjs precommit",
    "test:critical": "node scripts/checks/run-vitest-suite.mjs critical-cli",
    "test:platform-critical": "node scripts/checks/run-vitest-suite.mjs platform-critical",
    "test:backend-critical": "node scripts/checks/run-vitest-suite.mjs backend-critical",
    "test:release:critical": "node scripts/checks/run-vitest-suite.mjs release-critical",
    "backend:live": "node scripts/checks/run-backend-live-suite.mjs",
    "backend:matrix": "bun run test:backend-critical && bun run backend:live",
    "coverage:workflow-suite": "node scripts/workflow/run-workflow-coverage-suite.mjs",
    "coverage:significant-suite": "node scripts/checks/run-significant-coverage-suite.mjs",
    "coverage:thresholds:check": "node scripts/checks/check-coverage-thresholds.mjs",
    "coverage": "vitest run --coverage",
    "arch:baseline": "node scripts/checks/check-depcruise-known-violations.mjs",
    "arch:deps": "depcruise --config depcruise.config.cjs --ignore-known .dependency-cruiser-known-violations.json --include-only '^packages/(agentplane|core|recipes|testkit)/src' --exclude '(^|/)(dist|node_modules)/' packages/agentplane/src packages/core/src packages/recipes/src packages/testkit/src",
    "arch:check": "bun run arch:baseline && bun run arch:deps",
    "knip:check": "node scripts/checks/check-knip-baseline.mjs",
    "knip:report": "knip --config knip.json --no-exit-code",
    "clone:check": "node scripts/checks/check-clone-baseline.mjs",
    "clone:report": "node scripts/checks/check-clone-baseline.mjs --report",
    "clone:baseline:update": "node scripts/checks/check-clone-baseline.mjs --update-baseline",
    "ci": "bun run ci:contract && bun run ci:test",
    "ci:contract": "bun run format:check && bun run schemas:check && bun run spec:examples:check && bun run release:acr-example:check && bun run agents:check && bun run policy:routing:check && bun run release:parity && bun run docs:bootstrap:check && bun run docs:onboarding:check && bun run docs:ia:check && bun run docs:scripts:check && bun run hotspots:check && bun run check:types-files && bun run vitest:projects:check && bun run guards:check && bun run lint:core && bun run logging:check && bun run arch:check && bun run knip:check && bun run coverage:thresholds:check",
    "ci:test": "bun run typecheck && bun run coverage && bun run coverage:significant",
    "ci:local": "node scripts/checks/run-local-ci.mjs --mode fast",
    "ci:local:smoke": "node scripts/checks/run-local-ci.mjs --mode smoke",
    "ci:local:fast": "node scripts/checks/run-local-ci.mjs --mode fast",
    "ci:local:full": "node scripts/checks/run-local-ci.mjs --mode full",
    "ci:local:profile": "node scripts/checks/profile-local-quality.mjs",
    "ci:agentplane": "node scripts/checks/ci-scope.mjs --scope agentplane",
    "ci:core": "node scripts/checks/ci-scope.mjs --scope core",
    "ci:recipes": "node scripts/checks/ci-scope.mjs --scope recipes",
    "ci:spec": "node scripts/checks/ci-scope.mjs --scope spec",
    "ci:testkit": "node scripts/checks/ci-scope.mjs --scope testkit",
    "dev:turbo:ls": "TURBO_TELEMETRY_DISABLED=1 turbo ls --output=json",
    "dev:turbo:affected": "node scripts/checks/run-turbo-local-ci.mjs --affected",
    "dev:turbo:graph": "mkdir -p .agentplane/cache && TURBO_TELEMETRY_DISABLED=1 turbo run build typecheck test --filter='./packages/*' --graph=.agentplane/cache/turbo-task-graph.mermaid",
    "dev:turbo:build": "TURBO_TELEMETRY_DISABLED=1 turbo run build --filter='./packages/*' --summarize",
    "dev:turbo:docs": "TURBO_TELEMETRY_DISABLED=1 turbo run typecheck build --filter='./website' --summarize",
    "dev:impact": "node scripts/checks/dev-impact.mjs",
    "dev:task-scope:check": "node scripts/checks/check-task-scope.mjs",
    "deps:triage": "node scripts/checks/deps-triage.mjs",
    "ci:local:turbo": "node scripts/checks/run-turbo-local-ci.mjs",
    "checks:run": "node scripts/checks/run-checks.mjs",
    "release:check": "bun run release:incidents:check && bun run release:acr-example:check && bun run --filter=@agentplaneorg/core build && bun run --filter=agentplane build && bun run --filter=@agentplane/testkit build && bun run --filter=@agentplaneorg/recipes build && node scripts/release-check.mjs",
    "release:check:registry": "node scripts/release/check-npm-version-availability.mjs",
    "release:version:bump": "node scripts/release/version-bump.mjs",
    "release:state": "node scripts/release/state.mjs",
    "release:candidate:prepare": "node scripts/release/candidate-prepare.mjs",
    "release:evidence:collect": "node scripts/release/evidence-collect.mjs",
    "release:next-action": "node scripts/release/next-action.mjs",
    "release:recover": "node scripts/release/check-release-recovery-state.mjs",
    "release:e2e:local": "node scripts/release/run-local-release-e2e.mjs",
    "release:smoke:published": "node scripts/release/check-published-packages.mjs",
    "release:postpublish:audit": "node scripts/release/audit-platform-publication.mjs",
    "release:distribution:generate": "node scripts/generate/generate-release-distribution.mjs",
    "release:distribution:check": "node scripts/generate/generate-release-distribution.mjs --check",
    "release:standalone:generate": "node scripts/generate/generate-standalone-cli-assets.mjs",
    "release:standalone:check": "node scripts/generate/generate-standalone-cli-assets.mjs --check",
    "release:standalone:smoke": "node scripts/release/smoke-standalone-cli-artifact.mjs",
    "release:homebrew:check": "node scripts/generate/render-homebrew-formula.mjs --check",
    "release:scoop:check": "node scripts/generate/render-scoop-manifest.mjs --check",
    "release:ghcr:check": "node scripts/generate/render-ghcr-image-metadata.mjs --check",
    "release:setup-action:check": "node scripts/generate/render-setup-agentplane-action.mjs --check",
    "release:demo:check": "node scripts/release/check-release-demo.mjs",
    "release:acr-example:check": "node scripts/checks/check-acr-example-version.mjs",
    "release:incidents:check": "node scripts/check-release-incidents.mjs",
    "release:tasks:check": "node scripts/release/check-task-registry-ready.mjs",
    "ci:release-extras": "bun run artifacts:check && bun run task-state:check && bun run build && bun run package:tarball:check && bun run package:install-smoke && bun run docs:cli:check && bun run docs:recipes:check && GIT_AUTHOR_NAME=agentplane-ci GIT_AUTHOR_EMAIL=agentplane-ci@example.com GIT_COMMITTER_NAME=agentplane-ci@example.com GIT_COMMITTER_EMAIL=agentplane-ci@example.com node scripts/checks/run-vitest-suite.mjs release-ci-base && bun run coverage:workflow-suite && bun run coverage:significant-suite && GIT_AUTHOR_NAME=agentplane-ci GIT_AUTHOR_EMAIL=agentplane-ci@example.com GIT_COMMITTER_NAME=agentplane-ci@example.com GIT_COMMITTER_EMAIL=agentplane-ci@example.com bun run test:release:critical",
    "release:ci-check": "bun run ci:contract && bun run ci:release-extras",
    "release:prepublish:fast": "bun run release:check",
    "release:prepublish:heavy": "bun run release:ci-check",
    "release:prepublish": "bun run release:prepublish:fast && bun run release:prepublish:heavy",
    "release:parity": "node scripts/release/check-release-parity.mjs",
    "artifacts:check": "node scripts/checks/check-agentplane-artifacts.mjs",
    "task-state:check": "node scripts/checks/check-task-state.mjs",
    "package:tarball:check": "node scripts/release/check-package-tarball.mjs",
    "package:install-smoke": "node scripts/release/check-local-tarball-install-smoke.mjs",
    "lint": "bun run lint:core && bun run lint:website",
    "lint:core": "eslint packages scripts eslint.config.cjs vitest.config.ts",
    "guards:check": "node scripts/checks/check-shared-guards.mjs",
    "lint:website": "eslint website",
    "workflows:lint": "node scripts/workflow/run-workflows-lint.mjs && node scripts/checks/check-workflow-command-contract.mjs && bun scripts/checks/check-lifecycle-parity.ts && node scripts/checks/check-critical-test-route.mjs",
    "workflows:command-check": "node scripts/checks/check-workflow-command-contract.mjs && bun scripts/checks/check-lifecycle-parity.ts && node scripts/checks/check-critical-test-route.mjs",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "format:changed": "node scripts/checks/check-changed-format.mjs",
    "hooks:install": "lefthook install",
    "agents:check": "node scripts/generate/sync-agent-templates.mjs check",
    "policy:routing:check": "node scripts/checks/check-policy-routing.mjs",
    "agents:sync": "node scripts/generate/sync-agent-templates.mjs sync",
    "schemas:check": "bun scripts/generate/sync-schemas.mjs check",
    "schemas:sync": "bun scripts/generate/sync-schemas.mjs sync",
    "spec:examples:check": "node scripts/checks/check-spec-examples.mjs",
    "hotspots:check": "node scripts/checks/hotspot-report.mjs --check --warning-lines 400 --oversized-lines 600 --test-warning-lines 1000 --oversized-test-lines 1300 && node scripts/checks/check-oversized-test-baseline.mjs --threshold-lines 1000",
    "check:types-files": "node scripts/checks/check-types-files.mjs",
    "vitest:projects:check": "node scripts/checks/check-vitest-projects.mjs",
    "coverage:significant": "node scripts/checks/check-significant-coverage.mjs",
    "coverage:workflow-harness": "node scripts/checks/check-workflow-harness-coverage.mjs",
    "workflow:wait-remote-checks": "node scripts/workflow/wait-remote-pr-checks.mjs",
    "workflow:github-protection:check": "node scripts/checks/check-github-protection-contract.mjs",
    "framework:dev:bootstrap": "node scripts/workflow/bootstrap-framework-dev.mjs",
    "bench:cli:cold": "node scripts/bench/measure-cli-cold-path.mjs",
    "bench:cli:perf": "node scripts/bench/measure-cli-perf.mjs",
    "bench:cli:cold:check": "node scripts/checks/check-cli-cold-baseline.mjs --baseline scripts/baselines/cli-cold-path-smoke.json --runs 1 --warmups 0 --attempts 3 --fixture local-basic --timeout-ms 10000",
    "bench:cli:diff": "node scripts/bench/compare-cli-perf.mjs",
    "bench:cli:time": "node scripts/bench/measure-cli-walltime.mjs",
    "bench:cli:time:check": "node scripts/checks/check-cli-walltime-baseline.mjs --warmups 1 --attempts 3",
    "bench:cli:time:diff": "node scripts/bench/compare-cli-walltime.mjs",
    "runner:codex:approval-probe": "bun scripts/workflow/run-runner-codex-approval-probe.mjs",
    "runner:codex:smoke": "bun scripts/run-runner-codex-smoke.mjs",
    "docs:cli:generate": "node packages/agentplane/dist/cli.js docs cli --out docs/user/cli-reference.generated.mdx",
    "docs:cli:check": "node scripts/checks/check-cli-reference-fresh.mjs",
    "docs:scripts:generate": "node scripts/generate/generate-scripts-readme.mjs",
    "docs:scripts:check": "node scripts/generate/generate-scripts-readme.mjs --check",
    "docs:recipes:generate": "node scripts/generate/generate-recipes-inventory.mjs",
    "docs:recipes:check": "node scripts/checks/check-recipes-inventory-fresh.mjs",
    "docs:bootstrap:generate": "node scripts/generate/generate-agent-bootstrap-doc.mjs",
    "docs:bootstrap:check": "node scripts/checks/check-agent-bootstrap-fresh.mjs",
    "docs:onboarding:check": "node scripts/checks/check-agent-onboarding-scenario.mjs",
    "docs:ia:check": "node scripts/checks/check-docs-ia.mjs",
    "docs:readme-header:generate": "node scripts/generate/generate-readme-header.mjs",
    "docs:readme-header:check": "node scripts/generate/generate-readme-header.mjs --check",
    "docs:site:generate": "node scripts/generate/generate-website-docs.mjs && node scripts/generate/generate-llms-full.mjs",
    "docs:site:generate:check": "node scripts/generate/generate-website-docs.mjs --check && node scripts/generate/generate-llms-full.mjs --check",
    "docs:site:typecheck": "bun run --cwd website typecheck",
    "docs:site:build": "bun run --cwd website build",
    "docs:site:build:check": "bun run --cwd website build:check",
    "docs:site:start": "bun run --cwd website start",
    "docs:site:check:design": "node scripts/checks/check-design-language.mjs",
    "docs:site:check": "bun run docs:site:generate:check && bun run docs:site:typecheck && bun run docs:site:build:check && bun run docs:site:check:design",
    "logging:check": "node scripts/checks/check-no-console.mjs",
    "release:bun:smoke": "node scripts/release/smoke-bun-compiled-cli.mjs",
    "assets:builtin:generate": "node scripts/generate/generate-builtin-assets.mjs",
    "assets:builtin:check": "node scripts/generate/generate-builtin-assets.mjs --check",
    "release:bun:generate": "bun run assets:builtin:generate && node scripts/generate/generate-bun-cli-assets.mjs",
    "release:bun:check": "bun run assets:builtin:check && node scripts/generate/generate-bun-cli-assets.mjs --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "4.1.6",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "jscpd": "^4.2.3",
    "knip": "^6.14.1",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vitest": "4.1.6"
  }
}

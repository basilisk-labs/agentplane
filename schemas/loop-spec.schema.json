{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentplane.org/schemas/loop-spec.schema.json",
  "title": "AgentPlane LoopSpec",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "title",
    "description",
    "kind",
    "status",
    "appliesTo",
    "permissions",
    "budgets",
    "steps",
    "transitions",
    "outputs",
    "stopConditions"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "kind": {
      "enum": [
        "intake",
        "planning",
        "implementation",
        "review",
        "recovery",
        "context",
        "release",
        "meta"
      ]
    },
    "status": { "enum": ["experimental", "trusted", "deprecated", "blocked"] },
    "appliesTo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blueprints": { "type": "array", "items": { "type": "string" } },
        "taskKinds": {
          "type": "array",
          "items": { "enum": ["analysis", "content", "docs", "code", "release", "ops", "context"] }
        },
        "taskTags": { "type": "array", "items": { "type": "string" } },
        "workflowModes": {
          "type": "array",
          "items": { "enum": ["direct", "branch_pr"] }
        }
      }
    },
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "approvedPlan": { "type": "boolean" },
        "cleanWorktree": { "type": "boolean" },
        "verifyStepsPresent": { "type": "boolean" },
        "hostedPr": { "type": "boolean" },
        "ciFailure": { "type": "boolean" }
      }
    },
    "permissions": { "type": "object" },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/metricDefinition" }
    },
    "budgets": {
      "type": "object",
      "required": ["maxIterations"],
      "properties": {
        "maxIterations": { "type": "integer", "minimum": 1 },
        "maxWallTimeMinutes": { "type": "integer", "minimum": 1 },
        "maxChangedFiles": { "type": "integer", "minimum": 1 },
        "maxDiffLines": { "type": "integer", "minimum": 1 },
        "maxAgentRuns": { "type": "integer", "minimum": 1 },
        "maxInputTokens": { "type": "integer", "minimum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "maxTotalTokens": { "type": "integer", "minimum": 1 },
        "maxNoProgressIterations": { "type": "integer", "minimum": 1 }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "command": { "type": "string" },
          "promptModule": { "type": "string" },
          "evaluator": { "type": "string" },
          "contract": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "schemaRef": { "type": "string", "minLength": 1 },
              "inputs": {
                "type": "array",
                "items": { "$ref": "#/$defs/contractField" }
              },
              "outputs": {
                "type": "array",
                "items": { "$ref": "#/$defs/contractField" }
              },
              "artifacts": {
                "type": "array",
                "items": { "$ref": "#/$defs/artifactContract" }
              }
            }
          },
          "when": { "type": "string" },
          "optional": { "type": "boolean" }
        }
      }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["if", "to", "decision"],
        "properties": {
          "from": { "type": "string" },
          "if": { "$ref": "#/$defs/condition" },
          "to": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "minLength": 1 }
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "stopConditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "reason", "decision"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "condition": {
      "enum": [
        "checks.ok && evaluator.verdict == 'pass'",
        "checks.failed && iteration < budgets.maxIterations",
        "budgets.exceeded",
        "remote_check.green",
        "local_check.failed && iteration < budgets.maxIterations",
        "classify_failure.kind == 'infra'",
        "docs_build.ok && evaluator.verdict == 'pass'",
        "docs_build.failed && iteration < budgets.maxIterations",
        "evaluator.verdict == 'pass'",
        "evaluator.verdict == 'findings'",
        "verify_context.ok && evaluator.verdict == 'pass'",
        "no_reusable_knowledge",
        "recheck.clean",
        "classify_safety.requires_human",
        "evaluator.verdict == 'rework'",
        "compare.candidate_better && no_policy_regression",
        "compare.regression_detected"
      ]
    },
    "contractField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "enum": ["string", "number", "boolean", "object", "array", "json", "path", "ref"]
        },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "artifactContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "description": { "type": "string" }
      }
    },
    "metricDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "enum": ["rule", "check", "evaluator", "aggregate"] },
        "weight": { "type": "number", "exclusiveMinimum": 0 },
        "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "required": { "type": "boolean" },
        "description": { "type": "string" },
        "refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}

{
  "name": "@agentplane/testkit",
  "version": "0.0.0",
  "description": "Test helpers for Agentplane audit-layer packages (internal package).",
  "keywords": [
    "agentplane",
    "agentplane-framework",
    "agent-audit",
    "testing",
    "testkit",
    "cli"
  ],
  "license": "MIT",
  "author": "Basilisk Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/basilisk-labs/agentplane.git"
  },
  "homepage": "https://agentplane.org",
  "bugs": {
    "url": "https://github.com/basilisk-labs/agentplane/issues"
  },
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./cli-core-lifecycle": {
      "types": "./dist/cli-core-lifecycle.d.ts",
      "default": "./dist/cli-core-lifecycle.js"
    },
    "./cli-core-pr-flow": {
      "types": "./dist/cli-core-pr-flow.d.ts",
      "default": "./dist/cli-core-pr-flow.js"
    },
    "./cli-core-tasks-query": {
      "types": "./dist/cli-core-tasks-query.d.ts",
      "default": "./dist/cli-core-tasks-query.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "default": "./dist/hooks.js"
    },
    "./guard": {
      "types": "./dist/guard.d.ts",
      "default": "./dist/guard.js"
    },
    "./recipes": {
      "types": "./dist/recipes.d.ts",
      "default": "./dist/recipes.js"
    },
    "./task": {
      "types": "./dist/task.d.ts",
      "default": "./dist/task.js"
    },
    "./release": {
      "types": "./dist/release.d.ts",
      "default": "./dist/release.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "default": "./dist/runner.js"
    }
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@agentplaneorg/core": "0.6.5"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "cd ../.. && vitest --config vitest.workspace.ts run --project testkit"
  }
}

{
  "name": "@agentplaneorg/recipes",
  "version": "0.5.0",
  "description": "Recipe modules for repeatable AgentPlane audit-layer workflows.",
  "keywords": [
    "agentplane",
    "agentplane-framework",
    "coding-agent",
    "agent-audit",
    "git-workflow",
    "recipes",
    "automation",
    "cli"
  ],
  "license": "MIT",
  "author": "Basilisk Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/basilisk-labs/agentplane.git"
  },
  "homepage": "https://agentplane.org",
  "bugs": {
    "url": "https://github.com/basilisk-labs/agentplane/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true}); require('node:fs').rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "build": "tsc -b && bun run build:bundle",
    "build:bundle": "node ../../scripts/prune-package-js.mjs dist && tsup && node ../../scripts/manifest.mjs build .",
    "typecheck": "tsc -b",
    "prepack": "bun run clean && bun run build && node ../../scripts/manifest.mjs sanitize .",
    "postpack": "node ../../scripts/manifest.mjs build .",
    "prepublishOnly": "node ../../scripts/enforce-github-publish.mjs && npm run prepack",
    "test": "bun test ./src/index.test.ts ./src/overlay.test.ts ./src/blueprint-extensions.test.ts"
  }
}

{
  "name": "@agentplaneorg/recipes",
  "version": "0.3.15",
  "description": "Recipe runtime helpers for the Agent Plane CLI.",
  "keywords": [
    "agentplane",
    "agentplane-framework",
    "recipes",
    "automation",
    "cli"
  ],
  "license": "MIT",
  "author": "Basilisk Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/basilisk-labs/agentplane.git"
  },
  "homepage": "https://github.com/basilisk-labs/agentplane",
  "bugs": {
    "url": "https://github.com/basilisk-labs/agentplane/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true}); require('node:fs').rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "build": "tsc -b && node ../../scripts/manifest.mjs build .",
    "typecheck": "tsc -b",
    "prepack": "bun run clean && bun run build",
    "prepublishOnly": "node ../../scripts/enforce-github-publish.mjs && npm run prepack",
    "test": "node --test"
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentplane.org/schemas/runner-handoff.schema.json",
  "title": "AgentPlane runner handoff (v1)",
  "description": "Connector-neutral cloud-to-runner handoff contract for preparing a hosted runner without granting lifecycle authority or executing repository mutations by itself.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_task_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_ref": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "git"
        },
        "repository": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "pattern": "^(?!\\/)(?!\\\\)(?![A-Za-z]:)(?!.*:\\/\\/)(?!.*\\\\)(?!.*(?:^|\\/)\\.\\.(?:\\/|$))(?!.*\\.git$)[A-Za-z0-9_.-]+\\/[A-Za-z0-9_.-]+$"
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240,
          "pattern": "^(?!\\/)(?!\\\\)(?![A-Za-z]:)(?!.*:\\/\\/)(?!.*\\\\)(?!.*(?:^|\\/)\\.\\.(?:\\/|$))(?!.*\\.lock$)(?!.*@[{])(?!.*\\s).+$"
        },
        "commit_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,64}$"
        }
      },
      "required": ["kind", "repository", "ref"],
      "additionalProperties": false
    },
    "requested_by": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["human", "agent", "automation", "service", "unknown"]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        }
      },
      "required": ["type", "id"],
      "additionalProperties": false
    },
    "mode": {
      "type": "string",
      "enum": ["dry_run", "execute"]
    },
    "required_evidence": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["task_readme", "verification", "acr", "trace", "artifact", "custom"]
          },
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "required": {
            "default": true,
            "type": "boolean"
          }
        },
        "required": ["kind", "id"],
        "additionalProperties": false
      }
    },
    "upload_targets": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["evidence", "artifact", "trace", "acr", "log"]
          },
          "target_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          }
        },
        "required": ["kind", "target_id"],
        "additionalProperties": false
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "status": {
      "type": "string",
      "enum": ["requested", "accepted", "blocked", "expired", "cancelled"]
    },
    "kill_switch_checked": {
      "type": "object",
      "properties": {
        "checked_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "active": {
          "type": "boolean",
          "const": false
        }
      },
      "required": ["checked_at", "active"],
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "project_id",
    "workspace_id",
    "task_id",
    "repo_ref",
    "requested_by",
    "mode",
    "required_evidence",
    "upload_targets",
    "created_at",
    "expires_at",
    "status",
    "kill_switch_checked"
  ],
  "additionalProperties": false
}

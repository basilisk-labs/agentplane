{
  "name": "@agentplaneorg/core",
  "version": "0.4.3",
  "description": "Core libraries for AgentPlane repository-native task, policy, and verification workflows.",
  "keywords": [
    "agentplane",
    "agentplane-framework",
    "coding-agent",
    "agent-audit",
    "git-workflow",
    "core",
    "tasks",
    "workflow",
    "cli"
  ],
  "license": "MIT",
  "author": "Basilisk Labs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basilisk-labs/agentplane.git"
  },
  "homepage": "https://agentplane.org",
  "bugs": {
    "url": "https://github.com/basilisk-labs/agentplane/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./commit": {
      "types": "./dist/commit/index.d.ts",
      "import": "./dist/commit/index.js",
      "default": "./dist/commit/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "import": "./dist/fs/index.js",
      "default": "./dist/fs/index.js"
    },
    "./git": {
      "types": "./dist/git/index.d.ts",
      "import": "./dist/git/index.js",
      "default": "./dist/git/index.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js",
      "default": "./dist/logger.js"
    },
    "./process": {
      "types": "./dist/process/index.d.ts",
      "import": "./dist/process/index.js",
      "default": "./dist/process/index.js"
    },
    "./project": {
      "types": "./dist/project/index.d.ts",
      "import": "./dist/project/index.js",
      "default": "./dist/project/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js",
      "default": "./dist/schemas/index.js"
    },
    "./tasks": {
      "types": "./dist/tasks/index.d.ts",
      "import": "./dist/tasks/index.js",
      "default": "./dist/tasks/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true}); require('node:fs').rmSync('tsconfig.tsbuildinfo',{force:true});\"",
    "build": "tsc -b && bun run build:bundle",
    "build:bundle": "node ../../scripts/prune-package-js.mjs dist && tsup && node ../../scripts/manifest.mjs build .",
    "typecheck": "tsc -b",
    "prepack": "bun run clean && bun run build && node ../../scripts/manifest.mjs sanitize .",
    "postpack": "node ../../scripts/manifest.mjs build .",
    "prepublishOnly": "node ../../scripts/enforce-github-publish.mjs && npm run prepack"
  },
  "dependencies": {
    "canonicalize": "^3.0.0",
    "execa": "^5.1.1",
    "yaml": "^2.8.2",
    "zod": "^3",
    "zod-validation-error": "^5.0.0",
    "zod-to-json-schema": "^3"
  }
}

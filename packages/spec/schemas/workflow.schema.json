{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentplane.dev/schemas/workflow.schema.json",
  "title": "Agentplane Workflow Contract",
  "description": "Versioned WORKFLOW.md front matter. AgentPlane reads v1 and v2, normalizes both to v2, and rejects unsupported versions.",
  "anyOf": [
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "mode": {
          "type": "string",
          "enum": ["direct", "branch_pr"]
        },
        "owners": {
          "type": "object",
          "properties": {
            "orchestrator": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["orchestrator"],
          "additionalProperties": false
        },
        "approvals": {
          "type": "object",
          "properties": {
            "require_plan": {
              "type": "boolean"
            },
            "require_verify": {
              "type": "boolean"
            },
            "require_network": {
              "type": "boolean"
            }
          },
          "required": ["require_plan", "require_verify", "require_network"],
          "additionalProperties": false
        },
        "retry_policy": {
          "type": "object",
          "properties": {
            "normal_exit_continuation": {
              "type": "boolean"
            },
            "abnormal_backoff": {
              "type": "string",
              "const": "exponential"
            },
            "max_attempts": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "required": ["normal_exit_continuation", "abnormal_backoff", "max_attempts"],
          "additionalProperties": false
        },
        "timeouts": {
          "type": "object",
          "properties": {
            "stall_seconds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 86400
            }
          },
          "required": ["stall_seconds"],
          "additionalProperties": false
        },
        "in_scope_paths": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "version",
        "mode",
        "owners",
        "approvals",
        "retry_policy",
        "timeouts",
        "in_scope_paths"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 2
        },
        "workflow": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["direct", "branch_pr"]
            },
            "status_commit_policy": {
              "type": "string",
              "enum": ["off", "warn", "confirm"]
            },
            "commit_automation": {
              "type": "string",
              "enum": ["manual", "finish_only"]
            },
            "finish_auto_status_commit": {
              "type": "boolean"
            },
            "close_commit": {
              "type": "object",
              "properties": {
                "direct_dirty_policy": {
                  "default": "allow_other_task_readmes",
                  "type": "string",
                  "enum": ["allow_other_task_readmes", "strict"]
                }
              },
              "additionalProperties": {}
            },
            "artifacts_language": {
              "type": "string",
              "enum": ["any", "en"]
            },
            "closure_commit_requires_approval": {
              "type": "boolean"
            }
          },
          "required": ["mode"],
          "additionalProperties": {}
        },
        "owners": {
          "type": "object",
          "properties": {
            "orchestrator": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["orchestrator"],
          "additionalProperties": false
        },
        "approvals": {
          "type": "object",
          "properties": {
            "require_plan": {
              "default": true,
              "type": "boolean"
            },
            "require_network": {
              "default": true,
              "type": "boolean"
            },
            "require_verify": {
              "default": true,
              "type": "boolean"
            },
            "require_force": {
              "default": false,
              "type": "boolean"
            }
          },
          "additionalProperties": {}
        },
        "workspace": {
          "type": "object",
          "properties": {
            "agents_dir": {
              "type": "string",
              "minLength": 1
            },
            "tasks_path": {
              "type": "string",
              "minLength": 1
            },
            "workflow_dir": {
              "type": "string",
              "minLength": 1
            },
            "worktrees_dir": {
              "type": "string",
              "minLength": 1
            },
            "isolation": {
              "type": "string",
              "const": "per_task"
            },
            "cleanup": {
              "type": "string",
              "const": "after_finish"
            }
          },
          "additionalProperties": {}
        },
        "paths": {
          "type": "object",
          "properties": {
            "agents_dir": {
              "default": ".agentplane/agents",
              "type": "string",
              "minLength": 1
            },
            "tasks_path": {
              "default": ".agentplane/tasks.json",
              "type": "string",
              "minLength": 1
            },
            "workflow_dir": {
              "default": ".agentplane/tasks",
              "type": "string",
              "minLength": 1
            },
            "worktrees_dir": {
              "default": ".agentplane/worktrees",
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": {}
        },
        "tasks": {
          "type": "object",
          "properties": {
            "id_suffix_length_default": {
              "default": 6,
              "type": "integer",
              "minimum": 3,
              "maximum": 16
            },
            "verify": {
              "default": {
                "required_tags": ["code", "backend", "frontend"],
                "require_steps_for_primary": ["code", "data", "ops"],
                "require_verification_for_primary": ["code", "data", "ops"],
                "spike_tag": "spike",
                "enforce_on_plan_approve": true,
                "enforce_on_start_when_no_plan": true
              },
              "type": "object",
              "properties": {
                "required_tags": {
                  "default": ["code", "backend", "frontend"],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "require_steps_for_tags": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "require_steps_for_primary": {
                  "default": ["code", "data", "ops"],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "require_verification_for_primary": {
                  "default": ["code", "data", "ops"],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "spike_tag": {
                  "default": "spike",
                  "type": "string",
                  "minLength": 1
                },
                "enforce_on_plan_approve": {
                  "default": true,
                  "type": "boolean"
                },
                "enforce_on_start_when_no_plan": {
                  "default": true,
                  "type": "boolean"
                }
              },
              "additionalProperties": {}
            },
            "tags": {
              "default": {
                "primary_allowlist": ["code", "data", "research", "docs", "ops", "product", "meta"],
                "strict_primary": false,
                "fallback_primary": "meta",
                "lock_primary_on_update": true
              },
              "type": "object",
              "properties": {
                "primary_allowlist": {
                  "default": ["code", "data", "research", "docs", "ops", "product", "meta"],
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "strict_primary": {
                  "default": false,
                  "type": "boolean"
                },
                "fallback_primary": {
                  "default": "meta",
                  "type": "string",
                  "minLength": 1
                },
                "lock_primary_on_update": {
                  "default": true,
                  "type": "boolean"
                }
              },
              "additionalProperties": {}
            },
            "doc": {
              "default": {
                "sections": [
                  "Summary",
                  "Scope",
                  "Plan",
                  "Verify Steps",
                  "Verification",
                  "Rollback Plan",
                  "Findings"
                ],
                "required_sections": ["Summary", "Scope", "Plan", "Verification", "Rollback Plan"]
              },
              "type": "object",
              "properties": {
                "sections": {
                  "default": [
                    "Summary",
                    "Scope",
                    "Plan",
                    "Verify Steps",
                    "Verification",
                    "Rollback Plan",
                    "Findings"
                  ],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required_sections": {
                  "default": ["Summary", "Scope", "Plan", "Verification", "Rollback Plan"],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": {}
            },
            "comments": {
              "default": {
                "start": {
                  "prefix": "Start:",
                  "min_chars": 40
                },
                "blocked": {
                  "prefix": "Blocked:",
                  "min_chars": 40
                },
                "verified": {
                  "prefix": "Verified:",
                  "min_chars": 60
                }
              },
              "type": "object",
              "properties": {
                "start": {
                  "default": {
                    "prefix": "Start:",
                    "min_chars": 40
                  },
                  "type": "object",
                  "properties": {
                    "prefix": {
                      "type": "string",
                      "minLength": 1
                    },
                    "min_chars": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": ["prefix", "min_chars"],
                  "additionalProperties": {}
                },
                "blocked": {
                  "default": {
                    "prefix": "Blocked:",
                    "min_chars": 40
                  },
                  "type": "object",
                  "properties": {
                    "prefix": {
                      "type": "string",
                      "minLength": 1
                    },
                    "min_chars": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": ["prefix", "min_chars"],
                  "additionalProperties": {}
                },
                "verified": {
                  "default": {
                    "prefix": "Verified:",
                    "min_chars": 60
                  },
                  "type": "object",
                  "properties": {
                    "prefix": {
                      "type": "string",
                      "minLength": 1
                    },
                    "min_chars": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": ["prefix", "min_chars"],
                  "additionalProperties": {}
                }
              },
              "additionalProperties": {}
            },
            "backend": {
              "type": "object",
              "properties": {
                "config_path": {
                  "default": ".agentplane/backends/local/backend.json",
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": {}
            }
          },
          "additionalProperties": {}
        },
        "branch": {
          "type": "object",
          "properties": {
            "task_prefix": {
              "default": "task",
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!.*(?:^|\\/)\\.\\.(?:\\/|$))(?!.*\\/\\/)(?!\\/)(?!.*\\/$)[^ ~^:?*[\\\\]+$"
            },
            "task_close_prefix": {
              "default": "task-close",
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!.*(?:^|\\/)\\.\\.(?:\\/|$))(?!.*\\/\\/)(?!\\/)(?!.*\\/$)[^ ~^:?*[\\\\]+$"
            }
          },
          "additionalProperties": {}
        },
        "framework": {
          "type": "object",
          "properties": {
            "source": {
              "default": "https://github.com/basilisk-labs/agentplane",
              "type": "string",
              "minLength": 1
            },
            "last_update": {
              "default": null,
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time",
                  "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "cli": {
              "default": {
                "expected_version": null
              },
              "type": "object",
              "properties": {
                "expected_version": {
                  "default": null,
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              },
              "additionalProperties": {}
            }
          },
          "additionalProperties": {}
        },
        "execution": {
          "type": "object",
          "properties": {
            "profile": {
              "default": "balanced",
              "type": "string",
              "enum": ["conservative", "balanced", "aggressive"]
            },
            "reasoning_effort": {
              "default": "medium",
              "type": "string",
              "enum": ["low", "medium", "high", "xhigh"]
            },
            "text_verbosity": {
              "default": "medium",
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "tool_budget": {
              "default": {
                "discovery": 6,
                "implementation": 10,
                "verification": 6
              },
              "type": "object",
              "properties": {
                "discovery": {
                  "default": 6,
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                },
                "implementation": {
                  "default": 10,
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                },
                "verification": {
                  "default": 6,
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                }
              },
              "additionalProperties": {}
            },
            "stop_conditions": {
              "default": [
                "Missing required input blocks correctness.",
                "Requested action expands scope or risk beyond approved plan.",
                "Verification fails and remediation changes scope."
              ],
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "handoff_conditions": {
              "default": [
                "Role boundary reached (for example CODER -> TESTER/REVIEWER).",
                "Task depends_on prerequisites are incomplete.",
                "Specialized agent is required."
              ],
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "unsafe_actions_requiring_explicit_user_ok": {
              "default": [
                "Destructive git history operations.",
                "Outside-repo read/write.",
                "Credential, keychain, or SSH material changes."
              ],
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": {}
        },
        "runner": {
          "type": "object",
          "properties": {
            "default_adapter": {
              "default": "codex",
              "type": "string",
              "enum": ["codex", "custom", "hermes"]
            },
            "trace": {
              "default": {
                "mode": "raw",
                "max_tail_bytes": 65536,
                "capture_stderr": true,
                "retention": "keep",
                "compression": "none",
                "redact_patterns": []
              },
              "type": "object",
              "properties": {
                "mode": {
                  "default": "raw",
                  "type": "string",
                  "enum": ["raw", "off"]
                },
                "max_tail_bytes": {
                  "default": 65536,
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "capture_stderr": {
                  "default": true,
                  "type": "boolean"
                },
                "retention": {
                  "default": "keep",
                  "type": "string",
                  "enum": ["keep", "remove_on_success", "remove_always"]
                },
                "compression": {
                  "default": "none",
                  "type": "string",
                  "enum": ["none", "gzip"]
                },
                "redact_patterns": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "timeouts": {
              "default": {
                "wall_clock_ms": 900000,
                "idle_ms": 180000,
                "terminate_grace_ms": 1500
              },
              "type": "object",
              "properties": {
                "wall_clock_ms": {
                  "default": 900000,
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "idle_ms": {
                  "default": 180000,
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "terminate_grace_ms": {
                  "default": 1500,
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "additionalProperties": false
            },
            "custom": {
              "type": "object",
              "properties": {
                "command": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "env": {
                  "default": {},
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "enforcement": {
                  "type": "object",
                  "properties": {
                    "mode": {
                      "type": "string",
                      "enum": ["none", "codex_sandbox_full_auto"]
                    },
                    "platform": {
                      "type": "string",
                      "enum": ["auto", "macos", "linux", "windows"]
                    }
                  },
                  "additionalProperties": {}
                }
              },
              "required": ["command"],
              "additionalProperties": {}
            }
          },
          "additionalProperties": {}
        },
        "feedback": {
          "type": "object",
          "properties": {
            "github_issues": {
              "default": {
                "enabled": false,
                "repository": "basilisk-labs/agentplane",
                "transport": "github",
                "cloud_endpoint": "https://agentplane.cloud/api/feedback/issues",
                "allow_anonymous_cloud": false,
                "prompt_on_internal_error": true,
                "include_insights_report": true,
                "dedupe": true,
                "labels": ["agentplane-feedback", "bug"]
              },
              "type": "object",
              "properties": {
                "enabled": {
                  "default": false,
                  "type": "boolean"
                },
                "repository": {
                  "default": "basilisk-labs/agentplane",
                  "type": "string",
                  "minLength": 1
                },
                "transport": {
                  "default": "github",
                  "type": "string",
                  "enum": ["github", "cloud", "auto"]
                },
                "cloud_endpoint": {
                  "default": "https://agentplane.cloud/api/feedback/issues",
                  "type": "string",
                  "minLength": 1
                },
                "allow_anonymous_cloud": {
                  "default": false,
                  "type": "boolean"
                },
                "prompt_on_internal_error": {
                  "default": true,
                  "type": "boolean"
                },
                "include_insights_report": {
                  "default": true,
                  "type": "boolean"
                },
                "dedupe": {
                  "default": true,
                  "type": "boolean"
                },
                "labels": {
                  "default": ["agentplane-feedback", "bug"],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": {}
            }
          },
          "additionalProperties": {}
        },
        "recipes": {
          "type": "object",
          "properties": {
            "storage_default": {
              "default": "copy",
              "type": "string",
              "enum": ["link", "copy"]
            }
          },
          "additionalProperties": {}
        },
        "commit": {
          "type": "object",
          "properties": {
            "generic_tokens": {
              "default": ["start", "status", "mark", "done", "wip", "update", "tasks", "task"],
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "dco": {
              "default": {
                "enabled": false,
                "name": null,
                "email": null
              },
              "type": "object",
              "properties": {
                "enabled": {
                  "default": false,
                  "type": "boolean"
                },
                "name": {
                  "default": null,
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "email": {
                  "default": null,
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              },
              "additionalProperties": {}
            }
          },
          "additionalProperties": {}
        },
        "acr": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "version": {
              "default": "0.1.0",
              "type": "string",
              "const": "0.1.0"
            },
            "write_on_finish": {
              "default": true,
              "type": "boolean"
            },
            "require_for_pr_check": {
              "default": false,
              "type": "boolean"
            },
            "default_validation_mode": {
              "default": "local",
              "type": "string",
              "enum": ["schema", "local", "ci"]
            },
            "include_model_identity": {
              "default": "when_known",
              "type": "string",
              "enum": ["never", "when_known", "always"]
            },
            "include_prompts": {
              "default": false,
              "type": "boolean",
              "const": false
            },
            "include_tool_outputs": {
              "default": false,
              "type": "boolean",
              "const": false
            }
          },
          "additionalProperties": {}
        },
        "scheduler": {
          "type": "object",
          "properties": {
            "concurrency": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "poll_interval_ms": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "retry_policy": {
              "type": "object",
              "properties": {
                "normal_exit_continuation": {
                  "type": "boolean"
                },
                "abnormal_backoff": {
                  "type": "string",
                  "const": "exponential"
                },
                "max_attempts": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 100
                }
              },
              "required": ["normal_exit_continuation", "abnormal_backoff", "max_attempts"],
              "additionalProperties": false
            },
            "timeouts": {
              "type": "object",
              "properties": {
                "stall_seconds": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 86400
                }
              },
              "required": ["stall_seconds"],
              "additionalProperties": false
            }
          },
          "additionalProperties": {}
        },
        "evaluator": {
          "type": "object",
          "properties": {
            "max_rework_attempts": {
              "default": 3,
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            },
            "skepticism_level": {
              "default": "standard",
              "type": "string",
              "enum": ["standard", "strict", "paranoid"]
            },

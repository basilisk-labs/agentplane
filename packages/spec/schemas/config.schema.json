{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentplane.org/schemas/config.schema.json",
  "title": "agentplane config.json (v1)",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 1,
      "default": 1
    },
    "workflow_mode": {
      "type": "string",
      "enum": ["direct", "branch_pr"],
      "default": "direct"
    },
    "status_commit_policy": {
      "type": "string",
      "enum": ["off", "warn", "confirm"],
      "default": "warn"
    },
    "commit_automation": {
      "type": "string",
      "enum": ["manual", "finish_only"],
      "default": "manual"
    },
    "finish_auto_status_commit": {
      "type": "boolean",
      "default": false
    },
    "close_commit": {
      "type": "object",
      "properties": {
        "direct_dirty_policy": {
          "type": "string",
          "enum": ["allow_other_task_readmes", "strict"],
          "default": "allow_other_task_readmes"
        }
      },
      "additionalProperties": true,
      "default": {
        "direct_dirty_policy": "allow_other_task_readmes"
      }
    },
    "agents": {
      "type": "object",
      "properties": {
        "approvals": {
          "type": "object",
          "properties": {
            "require_plan": {
              "type": "boolean",
              "default": true
            },
            "require_network": {
              "type": "boolean",
              "default": true
            },
            "require_verify": {
              "type": "boolean",
              "default": true
            },
            "require_force": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": true,
          "default": {
            "require_plan": true,
            "require_network": true,
            "require_verify": true,
            "require_force": false
          }
        }
      },
      "additionalProperties": true,
      "default": {
        "approvals": {
          "require_plan": true,
          "require_network": true,
          "require_verify": true
        }
      }
    },
    "recipes": {
      "type": "object",
      "properties": {
        "storage_default": {
          "type": "string",
          "enum": ["link", "copy"],
          "default": "copy"
        }
      },
      "additionalProperties": true,
      "default": {
        "storage_default": "copy"
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["conservative", "balanced", "aggressive"],
          "default": "balanced"
        },
        "reasoning_effort": {
          "type": "string",
          "enum": ["low", "medium", "high", "xhigh"],
          "default": "medium"
        },
        "text_verbosity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "medium"
        },
        "tool_budget": {
          "type": "object",
          "properties": {
            "discovery": {
              "type": "integer",
              "minimum": 1,
              "default": 6
            },
            "implementation": {
              "type": "integer",
              "minimum": 1,
              "default": 10
            },
            "verification": {
              "type": "integer",
              "minimum": 1,
              "default": 6
            }
          },
          "additionalProperties": true,
          "default": {
            "discovery": 6,
            "implementation": 10,
            "verification": 6
          }
        },
        "stop_conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [
            "Missing required input blocks correctness.",
            "Requested action expands scope or risk beyond approved plan.",
            "Verification fails and remediation changes scope."
          ]
        },
        "handoff_conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [
            "Role boundary reached (for example CODER -> TESTER/REVIEWER).",
            "Task depends_on prerequisites are incomplete.",
            "Specialized agent is required."
          ]
        },
        "unsafe_actions_requiring_explicit_user_ok": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [
            "Destructive git history operations.",
            "Outside-repo read/write.",
            "Credential, keychain, or SSH material changes."
          ]
        }
      },
      "additionalProperties": true,
      "default": {
        "profile": "balanced",
        "reasoning_effort": "medium",
        "text_verbosity": "medium",
        "tool_budget": {
          "discovery": 6,
          "implementation": 10,
          "verification": 6
        },
        "stop_conditions": [
          "Missing required input blocks correctness.",
          "Requested action expands scope or risk beyond approved plan.",
          "Verification fails and remediation changes scope."
        ],
        "handoff_conditions": [
          "Role boundary reached (for example CODER -> TESTER/REVIEWER).",
          "Task depends_on prerequisites are incomplete.",
          "Specialized agent is required."
        ],
        "unsafe_actions_requiring_explicit_user_ok": [
          "Destructive git history operations.",
          "Outside-repo read/write.",
          "Credential, keychain, or SSH material changes."
        ]
      }
    },
    "runner": {
      "type": "object",
      "properties": {
        "default_adapter": {
          "type": "string",
          "enum": ["codex", "custom"],
          "default": "codex"
        },
        "trace": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["raw", "off"],
              "default": "raw"
            },
            "max_tail_bytes": {
              "type": "integer",
              "minimum": 0,
              "default": 65536
            },
            "capture_stderr": {
              "type": "boolean",
              "default": true
            },
            "retention": {
              "type": "string",
              "enum": ["keep", "remove_on_success", "remove_always"],
              "default": "keep"
            },
            "compression": {
              "type": "string",
              "enum": ["none", "gzip"],
              "default": "none"
            },
            "redact_patterns": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "mode": "raw",
            "max_tail_bytes": 65536,
            "capture_stderr": true,
            "retention": "keep",
            "compression": "none",
            "redact_patterns": []
          }
        },
        "timeouts": {
          "type": "object",
          "properties": {
            "wall_clock_ms": {
              "type": "integer",
              "minimum": 0,
              "default": 900000
            },
            "idle_ms": {
              "type": "integer",
              "minimum": 0,
              "default": 180000
            },
            "terminate_grace_ms": {
              "type": "integer",
              "minimum": 0,
              "default": 1500
            }
          },
          "additionalProperties": false,
          "default": {
            "wall_clock_ms": 900000,
            "idle_ms": 180000,
            "terminate_grace_ms": 1500
          }
        },
        "custom": {
          "type": "object",
          "properties": {
            "command": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "enforcement": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["none", "codex_sandbox_full_auto"]
                },
                "platform": {
                  "type": "string",
                  "enum": ["auto", "macos", "linux", "windows"]
                }
              },
              "additionalProperties": true
            }
          },
          "required": ["command"],
          "additionalProperties": true
        }
      },
      "additionalProperties": true,
      "default": {
        "default_adapter": "codex",
        "trace": {
          "mode": "raw",
          "max_tail_bytes": 65536,
          "capture_stderr": true,
          "retention": "keep",
          "compression": "none",
          "redact_patterns": []
        },
        "timeouts": {
          "wall_clock_ms": 900000,
          "idle_ms": 180000,
          "terminate_grace_ms": 1500
        }
      }
    },
    "feedback": {
      "type": "object",
      "properties": {
        "github_issues": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "repository": {
              "type": "string",
              "minLength": 1,
              "default": "basilisk-labs/agentplane"
            },
            "prompt_on_internal_error": {
              "type": "boolean",
              "default": true
            },
            "include_insights_report": {
              "type": "boolean",
              "default": true
            },
            "dedupe": {
              "type": "boolean",
              "default": true
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": ["agentplane-feedback", "bug"]
            }
          },
          "additionalProperties": true,
          "default": {
            "enabled": false,
            "repository": "basilisk-labs/agentplane",
            "prompt_on_internal_error": true,
            "include_insights_report": true,
            "dedupe": true,
            "labels": ["agentplane-feedback", "bug"]
          }
        }
      },
      "additionalProperties": true,
      "default": {
        "github_issues": {
          "enabled": false,
          "repository": "basilisk-labs/agentplane",
          "prompt_on_internal_error": true,
          "include_insights_report": true,
          "dedupe": true,
          "labels": ["agentplane-feedback", "bug"]
        }
      }
    },
    "acr": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "version": {
          "type": "string",
          "const": "0.1.0",
          "default": "0.1.0"
        },
        "write_on_finish": {
          "type": "boolean",
          "default": true
        },
        "require_for_pr_check": {
          "type": "boolean",
          "default": false
        },
        "default_validation_mode": {
          "type": "string",
          "enum": ["schema", "local", "ci"],
          "default": "local"
        },
        "include_model_identity": {
          "type": "string",
          "enum": ["never", "when_known", "always"],
          "default": "when_known"
        },
        "include_prompts": {
          "type": "boolean",
          "const": false,
          "default": false
        },
        "include_tool_outputs": {
          "type": "boolean",
          "const": false,
          "default": false
        }
      },
      "additionalProperties": true,
      "default": {
        "enabled": true,
        "version": "0.1.0",
        "write_on_finish": true,
        "require_for_pr_check": false,
        "default_validation_mode": "local",
        "include_model_identity": "when_known",
        "include_prompts": false,
        "include_tool_outputs": false
      }
    },
    "paths": {
      "type": "object",
      "properties": {
        "agents_dir": {
          "type": "string",
          "minLength": 1,
          "default": ".agentplane/agents"
        },
        "tasks_path": {
          "type": "string",
          "minLength": 1,
          "default": ".agentplane/tasks.json"
        },
        "workflow_dir": {
          "type": "string",
          "minLength": 1,
          "default": ".agentplane/tasks"
        },
        "worktrees_dir": {
          "type": "string",
          "minLength": 1,
          "default": ".agentplane/worktrees"
        }
      },
      "additionalProperties": true,
      "default": {
        "agents_dir": ".agentplane/agents",
        "tasks_path": ".agentplane/tasks.json",
        "workflow_dir": ".agentplane/tasks",
        "worktrees_dir": ".agentplane/worktrees"
      }
    },
    "branch": {
      "type": "object",
      "properties": {
        "task_prefix": {
          "type": "string",
          "minLength": 1,
          "default": "task"
        }
      },
      "additionalProperties": true,
      "default": {
        "task_prefix": "task"
      }
    },
    "framework": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1,
          "default": "https://github.com/basilisk-labs/agentplane"
        },
        "last_update": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "cli": {
          "type": "object",
          "properties": {
            "expected_version": {
              "type": ["string", "null"],
              "default": null
            }
          },
          "additionalProperties": true,
          "default": {
            "expected_version": null
          }
        }
      },
      "additionalProperties": true,
      "default": {
        "source": "https://github.com/basilisk-labs/agentplane",
        "last_update": null,
        "cli": {
          "expected_version": null
        }
      }
    },
    "tasks": {
      "type": "object",
      "properties": {
        "id_suffix_length_default": {
          "type": "integer",
          "minimum": 3,
          "maximum": 16,
          "default": 6
        },
        "verify": {
          "type": "object",
          "properties": {
            "required_tags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": ["code", "backend", "frontend"]
            },
            "require_steps_for_tags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "require_steps_for_primary": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": ["code", "data", "ops"]
            },
            "require_verification_for_primary": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": ["code", "data", "ops"]
            },
            "spike_tag": {
              "type": "string",
              "minLength": 1,
              "default": "spike"
            },
            "enforce_on_plan_approve": {
              "type": "boolean",
              "default": true
            },
            "enforce_on_start_when_no_plan": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": true,
          "default": {
            "required_tags": ["code", "backend", "frontend"],
            "require_steps_for_primary": ["code", "data", "ops"],
            "require_verification_for_primary": ["code", "data", "ops"],
            "spike_tag": "spike",
            "enforce_on_plan_approve": true,
            "enforce_on_start_when_no_plan": true
          }
        },
        "tags": {
          "type": "object",
          "properties": {
            "primary_allowlist": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1,
              "default": ["code", "data", "research", "docs", "ops", "product", "meta"]
            },
            "strict_primary": {
              "type": "boolean",
              "default": false
            },
            "fallback_primary": {
              "type": "string",
              "minLength": 1,
              "default": "meta"
            },
            "lock_primary_on_update": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": true,
          "default": {
            "primary_allowlist": ["code", "data", "research", "docs", "ops", "product", "meta"],
            "strict_primary": false,
            "fallback_primary": "meta",
            "lock_primary_on_update": true
          }
        },
        "doc": {
          "type": "object",
          "properties": {
            "sections": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": [
                "Summary",
                "Scope",
                "Plan",
                "Verify Steps",
                "Verification",
                "Rollback Plan",
                "Findings"
              ]
            },
            "required_sections": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": ["Summary", "Scope", "Plan", "Verification", "Rollback Plan"]
            }
          },
          "additionalProperties": true,
          "default": {
            "sections": [
              "Summary",
              "Scope",
              "Plan",
              "Verify Steps",
              "Verification",
              "Rollback Plan",
              "Findings"
            ],
            "required_sections": ["Summary", "Scope", "Plan", "Verification", "Rollback Plan"]
          }
        },
        "comments": {
          "type": "object",
          "properties": {
            "start": {
              "type": "object",
              "properties": {
                "prefix": {
                  "type": "string",
                  "minLength": 1
                },
                "min_chars": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": ["prefix", "min_chars"],
              "additionalProperties": true,
              "default": {
                "prefix": "Start:",
                "min_chars": 40
              }
            },
            "blocked": {
              "type": "object",
              "properties": {
                "prefix": {
                  "type": "string",
                  "minLength": 1
                },
                "min_chars": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": ["prefix", "min_chars"],
              "additionalProperties": true,
              "default": {
                "prefix": "Blocked:",
                "min_chars": 40
              }
            },
            "verified": {
              "type": "object",
              "properties": {
                "prefix": {
                  "type": "string",
                  "minLength": 1
                },
                "min_chars": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": ["prefix", "min_chars"],
              "additionalProperties": true,
              "default": {
                "prefix": "Verified:",
                "min_chars": 60
              }
            }
          },
          "additionalProperties": true,
          "default": {
            "start": {
              "prefix": "Start:",
              "min_chars": 40
            },
            "blocked": {
              "prefix": "Blocked:",
              "min_chars": 40
            },
            "verified": {
              "prefix": "Verified:",
              "min_chars": 60
            }
          }
        }
      },
      "additionalProperties": true,
      "default": {
        "id_suffix_length_default": 6,
        "verify": {
          "required_tags": ["code", "backend", "frontend"],
          "require_steps_for_primary": ["code", "data", "ops"],
          "require_verification_for_primary": ["code", "data", "ops"],
          "spike_tag": "spike",
          "enforce_on_plan_approve": true,
          "enforce_on_start_when_no_plan": true
        },
        "tags": {
          "primary_allowlist": ["code", "data", "research", "docs", "ops", "product", "meta"],
          "strict_primary": false,
          "fallback_primary": "meta",
          "lock_primary_on_update": true
        },
        "doc": {
          "sections": [
            "Summary",
            "Scope",
            "Plan",
            "Verify Steps",
            "Verification",
            "Rollback Plan",
            "Findings"
          ],
          "required_sections": ["Summary", "Scope", "Plan", "Verification", "Rollback Plan"]
        },
        "comments": {
          "start": {
            "prefix": "Start:",
            "min_chars": 40
          },
          "blocked": {
            "prefix": "Blocked:",
            "min_chars": 40
          },
          "verified": {
            "prefix": "Verified:",
            "min_chars": 60
          }
        }
      }
    },
    "evaluator": {
      "type": "object",
      "properties": {
        "max_rework_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 3
        }
      },
      "additionalProperties": true,
      "default": {
        "max_rework_attempts": 3
      }
    },
    "commit": {
      "type": "object",
      "properties": {
        "generic_tokens": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": ["start", "status", "mark", "done", "wip", "update", "tasks", "task"]
        },
        "dco": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "name": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "email": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            }
          },
          "additionalProperties": true,
          "default": {
            "enabled": false,
            "name": null,
            "email": null
          }
        }
      },
      "additionalProperties": true,
      "default": {
        "generic_tokens": ["start", "status", "mark", "done", "wip", "update", "tasks", "task"],
        "dco": {
          "enabled": false,
          "name": null,
          "email": null
        }
      }
    },
    "tasks_backend": {
      "type": "object",
      "properties": {
        "config_path": {
          "type": "string",
          "minLength": 1,
          "default": ".agentplane/backends/local/backend.json"
        }
      },
      "additionalProperties": true,
      "default": {
        "config_path": ".agentplane/backends/local/backend.json"
      }
    },
    "artifacts_language": {
      "type": "string",
      "enum": ["any", "en"],
      "default": "any"
    },
    "closure_commit_requires_approval": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": true
}

{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "types": ["node"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@agentplane/testkit": ["packages/testkit/src/index.ts"],
      "@agentplane/testkit/cli": ["packages/testkit/src/cli.ts"],
      "@agentplane/testkit/cli-core-lifecycle": ["packages/testkit/src/cli-core-lifecycle.ts"],
      "@agentplane/testkit/cli-core-pr-flow": ["packages/testkit/src/cli-core-pr-flow.ts"],
      "@agentplane/testkit/cli-core-tasks-query": ["packages/testkit/src/cli-core-tasks-query.ts"],
      "@agentplane/testkit/recipes": ["packages/testkit/src/recipes.ts"],
      "@agentplane/testkit/release": ["packages/testkit/src/release.ts"],
      "@agentplane/testkit/runner": ["packages/testkit/src/runner.ts"],
      "@agentplane/testkit/task": ["packages/testkit/src/task.ts"],
      "@agentplane/testkit/*": ["packages/testkit/src/*.ts"],
      "@agentplaneorg/core": ["packages/core/src/index.ts"],
      "@agentplaneorg/core/*": ["packages/core/src/*/index.ts", "packages/core/src/*"],
      "@agentplaneorg/recipes": ["packages/recipes/src/index.ts"],
      "@agentplaneorg/recipes/*": ["packages/recipes/src/*"]
    },
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "forceConsistentCasingInFileNames": true
  }
}
